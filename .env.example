# =============================
# Sherpa environment example
# Copy to .env and fill as needed
# =============================

# --- AI provider credentials (MiniMax only) ---
# Required for workflow planning/synthesis/fix.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic/v1
MINIMAX_MODEL=MiniMax-M2.5
# Optional compatibility overrides (normally keep empty):
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENCODE_MODEL=

# --- Runtime behavior ---
SHERPA_CODEX_CLI=opencode
SHERPA_PARALLEL_FUZZERS=2
SHERPA_RUN_UNLIMITED_ROUND_BUDGET_SEC=7200
SHERPA_EXECUTOR_MODE=local_thread
SHERPA_K8S_NAMESPACE=sherpa
SHERPA_K8S_WORKER_IMAGE=sherpa-web:latest
SHERPA_K8S_JOB_SERVICE_ACCOUNT=sherpa-web
SHERPA_K8S_PVC_TMP=sherpa-shared-tmp
SHERPA_K8S_PVC_OUTPUT=sherpa-shared-output
SHERPA_K8S_PVC_OSS_FUZZ=sherpa-oss-fuzz
SHERPA_K8S_PVC_CONFIG=sherpa-config
SHERPA_K8S_PVC_JOB_LOGS=sherpa-job-logs
SHERPA_DOCKER_NETWORK_PRECHECK=1
SHERPA_GITNEXUS_AUTO_ANALYZE=1
SHERPA_GITNEXUS_SKIP_EMBEDDINGS=1
SHERPA_OPENCODE_CONFIG_PATH=/app/config/opencode.generated.json

# --- Paths (compose defaults) ---
SHERPA_DEFAULT_OSS_FUZZ_DIR=/shared/oss-fuzz
SHERPA_OUTPUT_DIR=/shared/output

# --- Docker daemon options ---
# Default docker registry mirror: xuanyuan
SHERPA_DOCKER_REGISTRY_MIRROR=https://7m856d3fdvb9yp.xuanyuan.run
SHERPA_DOCKER_DNS_1=1.1.1.1
SHERPA_DOCKER_DNS_2=8.8.8.8

# --- Optional networking/proxy/mirror ---
SHERPA_OSS_FUZZ_REPO_URL=https://github.com/google/oss-fuzz.git
SHERPA_GIT_MIRRORS=https://github.com
SHERPA_GIT_DOCKER_IMAGE=m.daocloud.io/docker.io/alpine/git
SHERPA_DOCKER_PROXY_HOST=host.docker.internal
SHERPA_DOCKER_HTTP_PROXY=
SHERPA_DOCKER_HTTPS_PROXY=
SHERPA_DOCKER_NO_PROXY=

# --- Job store / restore (Postgres only) ---
DATABASE_URL=postgresql://sherpa:sherpa@postgres:5432/sherpa
POSTGRES_DB=sherpa
POSTGRES_USER=sherpa
POSTGRES_PASSWORD=sherpa
SHERPA_WEB_AUTO_RESUME_ON_START=0
SHERPA_WEB_RESTORE_LOG_MAX_CHARS=200000

# --- Optional frontend telemetry ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Gateway HTTPS ---
# Default domain for local TLS certificate CN/SAN.
SHERPA_GATEWAY_TLS_HOST=sherpa-gateway.sherpa.orb.local
# HTTPS host port mapping for gateway.
SHERPA_GATEWAY_HTTPS_PORT=443
# Self-signed cert validity days.
SHERPA_GATEWAY_TLS_DAYS=3650
